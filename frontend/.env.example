# API Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Google Maps API Key (required for location services)
REACT_APP_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
REACT_APP_GOOGLE_MAPS_LIBRARIES=places,geometry
REACT_APP_GOOGLE_MAPS_VERSION=weekly

# Development API endpoints
REACT_APP_GOOGLE_MAPS_GEOCODING_API=https://maps.googleapis.com/maps/api/geocode/json
REACT_APP_GOOGLE_MAPS_PLACES_API=https://maps.googleapis.com/maps/api/place/autocomplete/json

# Optional: Restrict API key to specific domains
# REACT_APP_GOOGLE_MAPS_ALLOWED_DOMAINS=yourdomain.com,localhost
# and never commit this file to version control. Add .env to your .gitignore file.

# For production, set these environment variables in your hosting provider's
# environment configuration, not in this file.
